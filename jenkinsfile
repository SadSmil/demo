pipeline {
    agent {
        docker {
            image 'maven:3.9-eclipse-temurin-17'
            args '-u=root'
        }
    }

    parameters {
        booleanParam(name: 'LANCER_TOUS_LES_TESTS', defaultValue: false, description: 'Cocher pour lancer tous les tests')
        choice(name: 'TAG', choices: ['@creation','@brand1'], description: 'Choisir le tag à lancer')
    }

    stages {

        stage('Lancer les tests Karate') {
            steps {
                script {
                    if (params.LANCER_TOUS_LES_TESTS) {
                        echo "Lancement de TOUS les tests..."
                        sh 'mvn test'
                    } else {
                        echo "Lancement du tag : ${params.TAG}"
                        sh "mvn test -Dkarate.options='--tags ${params.TAG}'"
                    }
                    // On garde les résultats Allure avant que le conteneur ne soit détruit
                    stash name: 'allure-results-stash', includes: 'target/allure-results/**'
                }
            }
        }

       stage('Rapport') {
            steps {
                script {
                    // On récupère les résultats sur l'hôte Jenkins
                    unstash 'allure-results-stash'
                    
                    // Génération du rapport via le plugin Allure (qui a accès aux outils locaux)
                    allure([
                        includeProperties: false,
                        jdk: '',
                        properties: [],
                        reportBuildPolicy: 'ALWAYS',
                        results: [[path: 'target/allure-results']]
                    ])
                }
            }
        }
    }
}